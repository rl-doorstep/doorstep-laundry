// Doorstep Laundry Service - Prisma schema
// Compatible with PostgreSQL (Supabase, Railway)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  customer
  staff
  admin
}

enum OrderStatus {
  scheduled
  picked_up
  ready_for_wash
  in_progress
  waiting_for_payment
  ready_for_delivery
  out_for_delivery
  delivered
  cancelled
}

enum LoadStatus {
  ready_for_pickup
  incoming
  ready_for_wash
  washing
  drying
  folding
  cleaned
  ready_for_delivery
  out_for_delivery
  delivered
}

model User {
  id                       String    @id @default(cuid())
  email                    String    @unique
  name                     String?
  phone                    String?
  role                     Role      @default(customer)
  passwordHash             String?   @map("password_hash")
  authProvider             String?   @map("auth_provider")
  customPricePerPoundCents Int?      @map("custom_price_per_pound_cents")
  nmgrtExempt              Boolean   @default(false) @map("nmgrt_exempt")
  defaultLoadOptions        Json?     @map("default_load_options")
  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime  @updatedAt @map("updated_at")

  addresses           Address[]
  orders              Order[]   @relation("CustomerOrders")
  staffAssignments    StaffAssignment[]
  driverLocations     DriverLocation[]
  driverRuns          DriverRun[]
  orderStatusChanges  OrderStatusHistory[]
  passwordResetTokens PasswordResetToken[]
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([expiresAt])
}

model Address {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  label      String
  street     String
  city       String
  state      String
  zip        String
  isDefault  Boolean  @default(false) @map("is_default")
  createdAt  DateTime @default(now()) @map("created_at")

  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  pickupOrders    Order[] @relation("PickupAddress")
  deliveryOrders  Order[] @relation("DeliveryAddress")
}

model Order {
  id                 String      @id @default(cuid())
  orderNumber        String      @unique @map("order_number")
  customerId         String      @map("customer_id")
  pickupAddressId    String      @map("pickup_address_id")
  deliveryAddressId String      @map("delivery_address_id")
  status             OrderStatus @default(scheduled)
  pickupDate         DateTime    @map("pickup_date") @db.Date
  deliveryDate      DateTime    @map("delivery_date") @db.Date
  pickupTimeSlot    String?     @map("pickup_time_slot")
  deliveryTimeSlot  String?     @map("delivery_time_slot")
  notes              String?
  numberOfLoads           Int         @default(1) @map("number_of_loads")
  totalCents              Int         @map("total_cents")
  orderPricePerPoundCents Int?        @map("order_price_per_pound_cents")
  nmgrtExempt             Boolean?    @map("nmgrt_exempt")
  stripePaymentId         String?     @map("stripe_payment_id")
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")

  customer         User     @relation("CustomerOrders", fields: [customerId], references: [id], onDelete: Cascade)
  pickupAddress    Address  @relation("PickupAddress", fields: [pickupAddressId], references: [id])
  deliveryAddress  Address  @relation("DeliveryAddress", fields: [deliveryAddressId], references: [id])
  statusHistory    OrderStatusHistory[]
  staffAssignments StaffAssignment[]
  orderLoads       OrderLoad[]

  @@index([status, pickupDate])
  @@index([customerId, createdAt])
}

model OrderLoad {
  id             String     @id @default(cuid())
  orderId        String     @map("order_id")
  loadNumber     Int        @map("load_number")
  loadCode       String?    @unique @map("load_code")
  status         LoadStatus @default(ready_for_pickup)
  location       String?    @map("location")
  weightLbs      Float?     @map("weight_lbs")
  hotWater       Boolean    @default(false) @map("hot_water")
  bleach         Boolean    @default(false) @map("bleach")
  hypoallergenic Boolean    @default(false) @map("hypoallergenic")
  fabricSoftener Boolean    @default(false) @map("fabric_softener")
  delicateCycle  Boolean    @default(false) @map("delicate_cycle")
  extraRinse     Boolean    @default(false) @map("extra_rinse")
  scentFree      Boolean    @default(false) @map("scent_free")
  coldWaterOnly  Boolean    @default(false) @map("cold_water_only")
  hangDry        Boolean    @default(false) @map("hang_dry")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([orderId, loadNumber])
  @@index([orderId])
}

model OrderStatusHistory {
  id          String      @id @default(cuid())
  orderId     String      @map("order_id")
  status      OrderStatus
  note        String?
  changedById String?     @map("changed_by_id")
  createdAt   DateTime    @default(now()) @map("created_at")

  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  changedBy User? @relation(fields: [changedById], references: [id], onDelete: SetNull)

  @@index([orderId])
}

model LoadLocation {
  id        String   @id @default(cuid())
  name      String   @unique @map("name")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
}

model OrderSequence {
  id          String   @id @default(cuid())
  datePrefix  String   @unique @map("date_prefix") // YYYYMMDD
  lastNumber  Int      @default(0) @map("last_number")
  updatedAt   DateTime @updatedAt @map("updated_at")
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique @map("key")
  value     String   @map("value")
  updatedAt DateTime @updatedAt @map("updated_at")
}

model StaffAssignment {
  id        String   @id @default(cuid())
  orderId   String   @map("order_id")
  staffId   String   @map("staff_id")
  role      String   // e.g. "driver"
  assignedAt DateTime @default(now()) @map("assigned_at")

  order  Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  staff  User   @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([orderId, staffId, role])
  @@index([orderId])
  @@index([staffId])
}

model DriverLocation {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  lat       Float    @map("lat")
  lng       Float    @map("lng")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DriverRun {
  id        String   @id @default(cuid())
  driverId  String   @map("driver_id")
  orderIds  Json     @map("order_ids") // array of order id strings
  startedAt DateTime @default(now()) @map("started_at")

  driver User @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@index([driverId])
  @@index([driverId, startedAt])
}
